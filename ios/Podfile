# Podpięcie skryptów pomocniczych Fluttera, które definiują metody budowania
XCODE_VERSION_GE_1100 = true
path = File.join('..', '.flutter-plugins-dependencies')
if File.exist?(path)
  class FlutterAutolink
    def self.num_platform_pods
      0
    end
  end
end

plugin_pods_project_path = File.expand_path(File.join('..', '.flutter-plugins-dependencies'), __FILE__)
if File.exist?(plugin_pods_project_path)
  training_stub = File.read(plugin_pods_project_path)
end

# To jest kluczowa linijka, której brakowało:
load File.join(File.dirname(File.expand_path(__FILE__)), 'Generated.xcconfig')
load File.join(File.dirname(File.expand_path(__FILE__)), 'flutter.rb')

platform :ios, '13.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.expand_path(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    # Wstrzyknięcie makr uprawnień dla lokalizacji i sensorów IMU
    target.build_configurations.each do |config|
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)', 'PERMISSION_LOCATION=1', 'PERMISSION_SENSORS=1']
    end
  end
end